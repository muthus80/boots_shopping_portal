# Application Environment Variables
# Copy this file to .env and fill in the values

# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/boots_shopping
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ─── Redis (optional — for session/cache) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Email (optional — for transactional email) ────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=smtp-password
SMTP_FROM=no-reply@example.com
SMTP_TLS=true

# ─── Stripe (optional — for payment processing) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Sentry (optional — for error tracking) ────────────────────────────────────
SENTRY_DSN=

# ─── File Storage (optional — for product images) ──────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=boots-shopping-assets
AWS_S3_REGION=us-east-1